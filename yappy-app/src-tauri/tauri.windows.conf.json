{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "allowDowngrades": true,
      "wix": {
        "language": ["en-US"],
        "fragmentPaths": []
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installMode": "perUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
